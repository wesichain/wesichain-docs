---
import SiteLayout from './SiteLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { getDocsFlatNav } from '../data/docs-nav';

interface Props {
  title: string;
  description?: string;
  headings?: Array<{
    depth: number;
    slug: string;
    text: string;
  }>;
  datePublished?: string;
  dateModified?: string;
  currentSlug?: string;
  group?: string;
  lastUpdated?: string;
}

const {
  title,
  description,
  headings = [],
  datePublished,
  dateModified,
  currentSlug,
  group,
  lastUpdated,
} = Astro.props;

let prev: { href: string; title: string } | undefined;
let next: { href: string; title: string } | undefined;

if (currentSlug) {
  const flat = await getDocsFlatNav();
  const idx = flat.findIndex(e => e.slug === currentSlug);
  if (idx > 0) prev = flat[idx - 1];
  if (idx >= 0 && idx < flat.length - 1) next = flat[idx + 1];
}

const editUrl = currentSlug
  ? `https://github.com/wesichain/wesichain/blob/main/wesichain-docs/src/content/docs/${currentSlug}.mdx`
  : undefined;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": new URL(Astro.url.pathname, Astro.site).toString()
  },
  "headline": title.substring(0, 110),
  "description": description,
  "url": new URL(Astro.url.pathname, Astro.site).toString(),
  "author": {
    "@type": "Organization",
    "name": "Wesichain"
  },
  "inLanguage": "en-US",
  "publisher": {
    "@type": "Organization",
    "name": "Wesichain",
    "logo": {
      "@type": "ImageObject",
      "url": new URL('/favicon.svg', Astro.site).toString()
    }
  },
  ...(datePublished && { datePublished }),
  ...(dateModified && { dateModified })
};
---

<SiteLayout title={title} description={description} variant="docs" schema={articleSchema}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex gap-8 py-10">

      <Sidebar />

      <article class="flex-1 min-w-0">

        <!-- Breadcrumbs -->
        {group && (
          <nav aria-label="Breadcrumb" class="mb-8 flex items-center gap-1.5 text-xs text-neutral-600 font-mono">
            <a href="/docs/getting-started/installation" class="hover:text-neutral-300 transition-colors">Docs</a>
            <span aria-hidden="true">/</span>
            <span class="text-neutral-500">{group}</span>
            <span aria-hidden="true">/</span>
            <span class="text-neutral-300">{title}</span>
          </nav>
        )}

        <div class="prose-docs">
          <slot />
        </div>

        <!-- Footer meta row -->
        <div class="mt-10 flex items-center justify-between border-t border-neutral-800 pt-5">
          {lastUpdated && (
            <span class="text-xs font-mono text-neutral-700">
              Updated <time datetime={lastUpdated}>{new Date(lastUpdated).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
            </span>
          )}
          <span class="flex-1" />
          {editUrl && (
            <a
              href={editUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-xs text-neutral-600 hover:text-neutral-300 transition-colors font-mono"
            >
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
              </svg>
              Edit on GitHub
            </a>
          )}
        </div>

        <!-- Prev / Next navigation -->
        {(prev || next) && (
          <nav class="mt-8 grid grid-cols-2 gap-4">
            {prev ? (
              <a href={prev.href} class="group flex flex-col gap-1.5 rounded-lg border border-neutral-800 p-4 hover:border-neutral-700 transition-colors">
                <span class="text-[10px] font-mono text-neutral-600 uppercase tracking-widest">Previous</span>
                <span class="text-sm font-medium text-neutral-400 group-hover:text-white transition-colors">
                  ← {prev.title}
                </span>
              </a>
            ) : <span />}
            {next && (
              <a href={next.href} class="group flex flex-col items-end gap-1.5 rounded-lg border border-neutral-800 p-4 hover:border-neutral-700 transition-colors text-right">
                <span class="text-[10px] font-mono text-neutral-600 uppercase tracking-widest">Next</span>
                <span class="text-sm font-medium text-neutral-400 group-hover:text-white transition-colors">
                  {next.title} →
                </span>
              </a>
            )}
          </nav>
        )}

      </article>

      <TableOfContents headings={headings} />
    </div>
  </div>
</SiteLayout>
