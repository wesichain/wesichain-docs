---
import SiteLayout from './SiteLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import TableOfContents from '../components/TableOfContents.astro';

interface Props {
  title: string;
  description?: string;
  headings?: Array<{
    depth: number;
    slug: string;
    text: string;
  }>;
  datePublished?: string;
  dateModified?: string;
}

const { 
  title, 
  description, 
  headings = [],
  datePublished,
  dateModified
} = Astro.props;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": new URL(Astro.url.pathname, Astro.site).toString()
  },
  "headline": title.substring(0, 110),
  "description": description,
  "url": new URL(Astro.url.pathname, Astro.site).toString(),
  "author": {
    "@type": "Organization",
    "name": "Wesichain"
  },
  "inLanguage": "en-US",
  "publisher": {
    "@type": "Organization",
    "name": "Wesichain",
    "logo": {
      "@type": "ImageObject",
      "url": new URL('/favicon.svg', Astro.site).toString()
    }
  },
  ...(datePublished && { datePublished }),
  ...(dateModified && { dateModified })
};
---

<SiteLayout title={title} description={description} variant="docs" schema={articleSchema}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex gap-8 py-8">
      <Sidebar />

      <article class="flex-1 min-w-0">
        <div class="prose-docs">
          <slot />
        </div>
      </article>

      <TableOfContents headings={headings} />
    </div>
  </div>
</SiteLayout>
