---
import Search from './Search.astro';

const navLinks = [
  { href: '/docs/getting-started/installation', label: 'Docs' },
  { href: '/examples', label: 'Examples' },
  { href: '/crate-selector', label: 'Which Crate?', hideMd: true },
  { href: '/benchmarks', label: 'Benchmarks', hideMd: true },
  { href: '/changelog', label: 'Changelog' },
  { href: 'https://github.com/wesichain/wesichain', label: 'GitHub', external: true },
];

interface Props {
  variant?: 'landing' | 'docs';
}

const { variant = 'landing' } = Astro.props;
const currentPath = Astro.url.pathname;

const isActive = (href: string) => {
  if (href.startsWith('http')) return false;
  return currentPath === href || currentPath.startsWith(href + '/') || currentPath.startsWith(href.replace('/installation', ''));
};
---

<header class:list={[
  'sticky top-0 z-50 w-full',
  variant === 'landing' ? 'bg-neutral-950/90 backdrop-blur-sm' : 'bg-neutral-950',
]}>
  <div class="mx-auto flex h-14 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">

    <a href="/" class="flex items-center gap-2.5 shrink-0" aria-label="Wesichain Home">
      <div class="flex h-7 w-7 items-center justify-center rounded-md bg-rust-600 text-white font-bold text-sm tracking-tight" aria-hidden="true">
        W
      </div>
      <span class="text-[15px] font-bold tracking-tight text-white">Wesichain</span>
    </a>

    <nav class="hidden md:flex items-center gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noopener noreferrer' : undefined}
          class:list={[
            'rounded-md px-3 py-1.5 text-sm font-medium transition-colors',
            isActive(link.href)
              ? 'text-white bg-neutral-800'
              : 'text-neutral-400 hover:text-white hover:bg-neutral-900',
            link.hideMd ? 'hidden lg:block' : '',
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <Search />

      <a
        href="/docs/getting-started/installation"
        class="hidden sm:inline-flex items-center rounded-md bg-rust-600 px-4 py-2 text-sm font-semibold text-white hover:bg-rust-500 transition-colors"
      >
        Get Started
      </a>

      <button
        id="mobile-menu-toggle"
        class="md:hidden p-1.5 text-neutral-400 hover:text-white transition-colors rounded-md hover:bg-neutral-900"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="menu-icon-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
        <svg id="menu-icon-close" class="hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Bottom border — visible below header -->
  <div class="absolute bottom-0 inset-x-0 h-px bg-neutral-800"></div>

  <!-- Mobile menu -->
  <nav
    id="mobile-menu"
    class="hidden md:hidden bg-neutral-950 px-4 py-3 border-t border-neutral-800"
    aria-label="Mobile navigation"
  >
    <ul class="space-y-0.5">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
            class:list={[
              'block rounded-md px-3 py-2 text-sm transition-colors',
              isActive(link.href)
                ? 'bg-neutral-800 text-white font-medium'
                : 'text-neutral-400 hover:bg-neutral-900 hover:text-white',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  btn?.addEventListener('click', () => {
    const isExpanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!isExpanded));
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });
</script>
