---
import { splitterRows, typicalPythonSplitterRangeMibPerSec } from '../data/benchmarks';

const splitterPeak = Math.max(...splitterRows.map((row) => row.throughputMibPerSec));
const splitterFloor = Math.min(...splitterRows.map((row) => row.throughputMibPerSec));
const lowerMultiplier = Math.round(splitterPeak / typicalPythonSplitterRangeMibPerSec.high);
const upperMultiplier = Math.round(splitterPeak / typicalPythonSplitterRangeMibPerSec.low);

const painPoints = [
  {
    title: 'AI-Native Development',
    subtitle: 'Framework knowledge, instantly',
    description: `Other frameworks require days of documentation reading. Wesichain includes 11 Claude Code skills so AI agents understand the entire framework immediately.`,
    solution: `Download the Skills Pack, drag into Claude Code, and start building. "Create a ReAct agent" generates working code instantly.`,
    stat: '11',
    statLabel: 'built-in AI skills',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 2a10 10 0 1 0 10 10"/>
      <path d="M12 6v6l4 2"/>
      <circle cx="19" cy="5" r="3"/>
      <path d="M17.5 5H19m0 0v1.5"/>
    </svg>`,
  },
  {
    title: 'Performance That Scales',
    subtitle: 'Rust-native throughput',
    description: `Python agents hit the GIL wall. Text processing, chunking, and embedding operations block your event loop.`,
    solution: `Wesichain uses Tokio for true parallelism. Recursive text splitting hits ${splitterFloor}–${splitterPeak} MiB/s — ${lowerMultiplier}–${upperMultiplier}× typical Python performance.`,
    stat: `${lowerMultiplier}–${upperMultiplier}×`,
    statLabel: 'faster text processing',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
    </svg>`,
  },
  {
    title: 'Production-Ready',
    subtitle: 'Deploy anywhere',
    description: 'Python deployments need virtualenvs, dependency management, and platform-specific wheels.',
    solution: 'Compile to a single binary. Deploy to AWS Lambda, Kubernetes, or edge — no runtime dependencies. 2–5 MB memory per agent vs 80–150 MB in Python.',
    stat: '2–5 MB',
    statLabel: 'memory per agent',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
      <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
      <line x1="12" y1="22.08" x2="12" y2="12"/>
    </svg>`,
  },
];
---

<section class="py-24 border-y border-neutral-800" aria-labelledby="why-wesichain-heading">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <div class="mb-14">
      <p class="font-mono text-xs text-neutral-600 uppercase tracking-widest mb-3">Why Wesichain</p>
      <h2 id="why-wesichain-heading" class="text-3xl font-bold tracking-tight text-white max-w-xl">
        Built for developers who have been burned by the alternatives
      </h2>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      {painPoints.map((point) => (
        <div class="flex flex-col border border-neutral-800 rounded-xl p-7 hover:border-neutral-700 transition-colors bg-neutral-950">

          <!-- Icon -->
          <div class="text-rust-500 mb-5" aria-hidden="true" set:html={point.icon} />

          <!-- Title -->
          <h3 class="text-base font-semibold text-white mb-1">{point.title}</h3>
          <p class="text-xs font-mono text-neutral-600 mb-5">{point.subtitle}</p>

          <!-- Problem -->
          <div class="mb-4">
            <p class="text-xs font-semibold text-neutral-600 uppercase tracking-wider mb-2">The problem</p>
            <p class="text-sm text-neutral-400 leading-relaxed">{point.description}</p>
          </div>

          <!-- Solution -->
          <div class="mb-6">
            <p class="text-xs font-semibold text-neutral-600 uppercase tracking-wider mb-2">The solution</p>
            <p class="text-sm text-neutral-300 leading-relaxed">{point.solution}</p>
          </div>

          <!-- Stat — pushes to bottom -->
          <div class="mt-auto pt-5 border-t border-neutral-900">
            <span class="font-mono text-2xl font-bold text-rust-500">{point.stat}</span>
            <span class="ml-2 text-xs text-neutral-500">{point.statLabel}</span>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
