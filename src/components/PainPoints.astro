---
import { splitterRows, typicalPythonSplitterRangeMibPerSec } from '../data/benchmarks';

const splitterPeak = Math.max(...splitterRows.map((row) => row.throughputMibPerSec));
const splitterFloor = Math.min(...splitterRows.map((row) => row.throughputMibPerSec));
const lowerMultiplier = Math.round(splitterPeak / typicalPythonSplitterRangeMibPerSec.high);
const upperMultiplier = Math.round(splitterPeak / typicalPythonSplitterRangeMibPerSec.low);

const painPoints = [
  {
    icon: '🤖',
    label: 'robot',
    title: 'AI-Native Development',
    subtitle: 'Framework knowledge, instantly',
    description: `Other frameworks require days of documentation reading. Wesichain includes 11 Claude Code skills so AI agents understand the entire framework immediately.`,
    solution: `Download the Skills Pack, drag into Claude Code, and start building. "Create a ReAct agent" generates working code instantly.`,
    stat: '11',
    statLabel: 'built-in AI skills'
  },
  {
    icon: '⚡',
    label: 'lightning',
    title: 'Performance That Scales',
    subtitle: 'Rust-native throughput',
    description: `Python agents hit the GIL wall. Text processing, chunking, and embedding operations block your event loop.`,
    solution: `Wesichain uses Tokio for true parallelism. Recursive text splitting hits ${splitterFloor}-${splitterPeak} MiB/s — ${lowerMultiplier}-${upperMultiplier}x typical Python performance.`,
    stat: `${lowerMultiplier}-${upperMultiplier}x`,
    statLabel: 'faster text processing'
  },
  {
    icon: '📦',
    label: 'package',
    title: 'Production-Ready',
    subtitle: 'Deploy anywhere',
    description: 'Python deployments need virtualenvs, dependency management, and platform-specific wheels.',
    solution: 'Compile to a single binary. Deploy to AWS Lambda, Kubernetes, or edge — no runtime dependencies. 2-5 MB memory per agent vs 80-150 MB in Python.',
    stat: '2-5 MB',
    statLabel: 'memory per agent'
  }
];
---

<section class="py-24 bg-neutral-900/30 border-y border-neutral-800" aria-labelledby="why-wesichain-heading">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 id="why-wesichain-heading" class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Why Teams Choose Wesichain
      </h2>
      <p class="mt-4 text-lg text-neutral-400">
        Built for developers who want AI assistance, Rust performance, and production reliability
      </p>
    </div>

    <div class="grid gap-8 md:grid-cols-3">
      {painPoints.map((point) => (
        <div class="rounded-2xl border border-neutral-800 bg-neutral-900 p-8 hover:border-neutral-700 transition-colors">
          {/* Icon */}
          <div class="text-4xl mb-4" role="img" aria-label={point.label}>{point.icon}</div>

          {/* Title */}
          <h3 class="text-xl font-semibold text-white mb-2">
            {point.title}
          </h3>
          <p class="text-sm text-neutral-500 mb-4">{point.subtitle}</p>

          {/* Pain */}
          <div class="mb-4">
            <p class="text-sm text-red-400 mb-1 font-medium">The Problem</p>
            <p class="text-neutral-400 text-sm">{point.description}</p>
          </div>

          {/* Solution */}
          <div class="mb-6">
            <p class="text-sm text-green-400 mb-1 font-medium">The Solution</p>
            <p class="text-neutral-300 text-sm">{point.solution}</p>
          </div>

          {/* Stat */}
          <div class="pt-4 border-t border-neutral-800">
            <div class="flex items-baseline gap-2">
              <span class="text-3xl font-bold text-rust-500">{point.stat}</span>
              <span class="text-sm text-neutral-400">{point.statLabel}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
