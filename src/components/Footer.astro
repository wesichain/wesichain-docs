---
const currentYear = new Date().getFullYear();

const footerLinks = {
  Product: [
    { label: 'Documentation', href: '/docs/getting-started/installation' },
    { label: 'Examples', href: '/examples' },
    { label: 'Benchmarks', href: '/benchmarks' },
    { label: 'Changelog', href: '/changelog' },
    { label: 'Which Crate?', href: '/crate-selector' },
    { label: 'AI Skills Pack', href: '/docs/claude-code/skills-pack' },
  ],
  Community: [
    { label: 'GitHub', href: 'https://github.com/wesichain/wesichain', external: true },
    { label: 'Discussions', href: 'https://github.com/wesichain/wesichain/discussions', external: true },
    { label: 'Contributing', href: '/community#contributing' },
    { label: 'Roadmap', href: 'https://github.com/wesichain/wesichain/blob/main/wesichain/ROADMAP.md', external: true },
  ],
  Resources: [
    { label: 'Crates.io', href: 'https://crates.io/search?q=wesichain-', external: true },
    { label: 'docs.rs', href: 'https://docs.rs/wesichain-core', external: true },
    { label: 'MIT License', href: 'https://github.com/wesichain/wesichain/blob/main/LICENSE-MIT', external: true },
    { label: 'Apache 2.0', href: 'https://github.com/wesichain/wesichain/blob/main/LICENSE-APACHE', external: true },
  ],
};
---

<footer class="border-t border-neutral-800 bg-neutral-950">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">

    <!-- Top row: brand + links -->
    <div class="grid grid-cols-2 gap-10 md:grid-cols-4 lg:grid-cols-[2fr_1fr_1fr_1fr]">

      <!-- Brand column -->
      <div class="col-span-2 md:col-span-1">
        <div class="flex items-center gap-2 mb-4">
          <div class="flex h-7 w-7 items-center justify-center rounded-md bg-rust-600 text-white font-bold text-sm">
            W
          </div>
          <span class="text-[15px] font-bold tracking-tight text-white">Wesichain</span>
        </div>
        <p class="text-sm text-neutral-500 leading-relaxed max-w-xs">
          Production-grade LLM agents in Rust. Built for performance, designed for AI-assisted development.
        </p>
        <div class="mt-5 inline-flex items-center gap-1.5 rounded-md border border-neutral-800 px-2.5 py-1 text-xs font-mono text-neutral-600">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.27 11a.99.99 0 0 0-.24-.55l-6-7A1 1 0 0 0 13.27 3h-4a1 1 0 0 0-.76.35l-6 7a1 1 0 0 0 0 1.3l6 7A1 1 0 0 0 9.27 19h4a1 1 0 0 0 .76-.35l6-7a1 1 0 0 0 .24-.65z"/>
          </svg>
          Built with Rust + Tokio
        </div>
      </div>

      <!-- Link columns -->
      {Object.entries(footerLinks).map(([category, links]) => (
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-widest text-neutral-500 mb-4">{category}</h3>
          <ul class="space-y-2.5">
            {links.map(link => (
              <li>
                <a
                  href={link.href}
                  target={link.external ? '_blank' : undefined}
                  rel={link.external ? 'noopener noreferrer' : undefined}
                  class="text-sm text-neutral-400 hover:text-white transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom row -->
    <div class="mt-14 pt-6 border-t border-neutral-900 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <p class="text-xs text-neutral-700 font-mono">
        © {currentYear} Wesichain. Dual-licensed MIT and Apache-2.0.
      </p>
      <div class="flex items-center gap-4">
        <a
          href="https://github.com/wesichain/wesichain"
          target="_blank"
          rel="noopener noreferrer"
          class="text-neutral-700 hover:text-neutral-400 transition-colors"
          aria-label="GitHub"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
        <a
          href="https://crates.io/search?q=wesichain-"
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs font-mono text-neutral-700 hover:text-neutral-400 transition-colors"
        >
          crates.io
        </a>
        <a
          href="https://docs.rs/wesichain-core"
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs font-mono text-neutral-700 hover:text-neutral-400 transition-colors"
        >
          docs.rs
        </a>
      </div>
    </div>

  </div>
</footer>
