---
import { getDocsFlatNav } from '../data/docs-nav';

const flat = await getDocsFlatNav();

// Re-group for display (order is already correct in the flat list)
const grouped = flat.reduce((acc, entry) => {
  if (!acc[entry.group]) acc[entry.group] = [];
  acc[entry.group].push(entry);
  return acc;
}, {} as Record<string, typeof flat>);

const currentPath = Astro.url.pathname;
---

<aside class="hidden lg:block w-64 shrink-0">
  <nav class="sticky top-20 h-[calc(100vh-6rem)] overflow-y-auto pr-4">
    {Object.entries(grouped).map(([group, items]) => (
      <div class="mb-6">
        <h3 class="mb-2 px-3 text-xs font-semibold uppercase tracking-wider text-neutral-500">
          {group}
        </h3>
        <ul class="space-y-1">
          {items.map(entry => {
            const isActive = currentPath === entry.href || currentPath.startsWith(`${entry.href}/`);
            return (
              <li>
                <a
                  href={entry.href}
                  class:list={[
                    'block rounded-md px-3 py-2 text-sm transition-colors',
                    isActive
                      ? 'bg-rust-600/10 text-rust-500 font-medium'
                      : 'text-neutral-400 hover:bg-neutral-900 hover:text-white'
                  ]}
                >
                  {entry.title}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </nav>
</aside>
