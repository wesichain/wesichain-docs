---
import { getDocsFlatNav } from '../data/docs-nav';

const flat = await getDocsFlatNav();

const grouped = flat.reduce((acc, entry) => {
  if (!acc[entry.group]) acc[entry.group] = [];
  acc[entry.group].push(entry);
  return acc;
}, {} as Record<string, typeof flat>);

const currentPath = Astro.url.pathname;
---

<aside class="hidden lg:block w-60 shrink-0">
  <nav class="sticky top-20 h-[calc(100vh-6rem)] overflow-y-auto pr-2">
    {Object.entries(grouped).map(([group, items]) => (
      <div class="mb-7">
        <h3 class="mb-2 px-2 text-[10px] font-semibold uppercase tracking-widest text-neutral-600">
          {group}
        </h3>
        <ul class="space-y-0.5">
          {items.map(entry => {
            const isActive = currentPath === entry.href || currentPath.startsWith(`${entry.href}/`);
            return (
              <li>
                <a
                  href={entry.href}
                  class:list={[
                    'group flex items-center gap-2 rounded-md px-2 py-1.5 text-sm transition-colors',
                    isActive
                      ? 'bg-neutral-900 text-white font-medium'
                      : 'text-neutral-500 hover:text-neutral-200 hover:bg-neutral-900/50',
                  ]}
                >
                  {isActive && (
                    <span class="w-1 h-1 rounded-full bg-rust-500 shrink-0" aria-hidden="true"></span>
                  )}
                  {!isActive && (
                    <span class="w-1 h-1 rounded-full shrink-0" aria-hidden="true"></span>
                  )}
                  {entry.title}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </nav>
</aside>
