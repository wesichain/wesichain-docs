---
interface Props {
  headings: Array<{
    depth: number;
    slug: string;
    text: string;
  }>;
}

const { headings } = Astro.props;
---

{headings.length > 0 && (
  <aside class="hidden xl:block w-56 shrink-0">
    <nav class="sticky top-20">
      <p class="mb-4 text-[10px] font-semibold uppercase tracking-widest text-neutral-600">
        On this page
      </p>
      <ul class="space-y-1">
        {headings.filter(h => h.depth <= 3).map(heading => (
          <li>
            <a
              href={`#${heading.slug}`}
              class:list={[
                'block text-xs leading-snug transition-colors py-0.5',
                heading.depth === 2
                  ? 'text-neutral-500 hover:text-neutral-200'
                  : 'pl-3 text-neutral-600 hover:text-neutral-400 border-l border-neutral-800',
              ]}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </aside>
)}
